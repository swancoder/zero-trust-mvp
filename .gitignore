# ── Gradle ───────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ── IntelliJ IDEA ────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ── Eclipse ───────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# ── VS Code ───────────────────────────────────────────────
.vscode/

# ── macOS ─────────────────────────────────────────────────
.DS_Store

# ── Windows ───────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Compiled output ───────────────────────────────────────
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Environment / secrets — NEVER commit these ────────────
.env
.env.*
!.env.example
*.secret
*-secrets.yml
*-secrets.yaml
application-local.yml
application-local.yaml

# ── Docker ────────────────────────────────────────────────
docker-compose.override.yml

# ── Keycloak data (if mounted locally) ────────────────────
keycloak-data/

# ── Spring Boot DevTools ──────────────────────────────────
/tmp/

# ── JVM crash logs ────────────────────────────────────────
hs_err_pid*
replay_pid*

# ── Development certificates (generated by certs/generate-certs.sh) ──
# Private keys and keystores must NEVER be committed.
certs/*.key
certs/*.crt
certs/*.p12
certs/*.csr
certs/*.srl

# ── Claude Code local settings (machine-specific permissions) ──
.claude/settings.local.json
